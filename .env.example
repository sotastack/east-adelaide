# Copy to .env.local and fill in.

# Absolute site URL — used for metadata, sitemap and robots.
NEXT_PUBLIC_SITE_URL=https://east-adelaide.vercel.app

# Contact form (Resend). Without RESEND_API_KEY the form validates but
# does not send (it returns a clear "not configured" message).
RESEND_API_KEY=
# Where contact submissions are delivered:
CONTACT_TO_EMAIL=hello@eastadelaide.com.au
# Verified Resend sender (must be a domain you've verified in Resend;
# defaults to Resend's onboarding sender for local testing):
CONTACT_FROM_EMAIL="East Adelaide Capital Group <onboarding@resend.dev>"
